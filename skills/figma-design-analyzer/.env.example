# Figma设计分析器 - 环境变量配置
# 复制此文件为 .env 并填写实际值

# Figma个人访问令牌 (必填)
# 获取方式：登录Figma → Settings → Account → Personal access tokens
FIGMA_ACCESS_TOKEN=your_figma_personal_access_token_here

# 截图导出目录 (可选，默认为./exports)
FIGMA_EXPORT_DIR=./exports

# API请求超时(毫秒) (可选，默认为30000)
FIGMA_API_TIMEOUT=30000

# 调试模式 (可选，设置为true启用详细日志)
DEBUG=false

# Node.js内存限制 (可选，处理大型文件时建议增加)
# NODE_OPTIONS=--max-old-space-size=4096
